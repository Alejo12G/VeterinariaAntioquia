<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(VeterinariaAntioquia.Shared.Layout.MainLayout).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(VeterinariaAntioquia.Shared.Layout.MainLayout)">
                <NotAuthorized>
                    <p>No tienes permiso para ver esta página. Por favor loguéate.</p>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1"/>
        </Found>

        <NotFound>
            <PageTitle>Página no encontrada - Veterinaria</PageTitle>
            <LayoutView Layout="@typeof(VeterinariaAntioquia.Shared.Layout.MainLayout)">
                <div class="not-found-container" style="text-align: center; margin-top: 50px;">
                    <i class="fa-solid fa-face-frown-open" style="font-size: 4rem; color: #b2bec3;"></i>
                    <h1 style="color: #00bf63; font-size: 3rem;">404</h1>
                    <h2>¡Ups! Te saliste del mapa</h2>
                    <p>La ruta a la que intentas acceder no existe o esta en desarrollo.</p>
                    <a href="/" style="display: inline-block; margin-top: 20px; padding: 10px 20px; background: #00bf63; color: white; border-radius: 5px; text-decoration: none;">Volver al Inicio</a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>